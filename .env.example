# F1 Analytics System — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# PostgreSQL (main read-write connection for ingestion)
DATABASE_URL=postgresql://localhost/f1_analytics

# PostgreSQL (read-only connection for AI analyst — defense in depth)
DATABASE_URL_READONLY=postgresql://ai_readonly:f1_readonly_2025@localhost/f1_analytics

# Groq API key (for AI Analyst text-to-SQL layer)
GROQ_API_KEY=your_groq_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
